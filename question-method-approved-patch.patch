+<script>
+(function(){
+  "use strict";
+  var el = QM.el;
+  var TYPES = ["Definitional","Exploratory","Focusing","Application"];
+  var SRC = {
+    dict:   "A legal dictionary (or a general search)",
+    defs:   "The statute's definitions section",
+    ency:   "An encyclopedia or general search",
+    treat:  "A treatise",
+    survey: "An ALR annotation, Restatement, or 50-state survey",
+    prim:   "Primary authority — the statute, regulation, or leading case (found through a secondary source)",
+    cases:  "Cases with similar facts",
+    build:  "Multiple sources, built together by analogy — nothing is squarely on point"
+  };
+
+  /* Each item: q, type, tell (why), srcKey (right source), srcPool (distractor keys),
+     srcWhy — feedback keyed to the diagnostic logic. */
+  var BANK = [
+    { q: "What does \u201cconsideration\u201d mean in contract law?",
+      type: "Definitional", tell: "It asks what a word means — the wording is \u201cwhat does X mean.\u201d A working definition is enough to keep researching, so a legal dictionary answers it.",
+      srcKey: "dict", srcPool: ["dict","ency","treat"],
+      srcWhy: "For orientation, a legal dictionary gives the working definition. Precision-critical definitions come later, from the statute or case law." },
+    { q: "How does the law treat security deposits when a tenant moves out?",
+      type: "Exploratory", tell: "It asks what the landscape looks like — no rule is named, no standard presupposed. That is an exploratory question, no-clue flavor.",
+      srcKey: "ency", srcPool: ["ency","cases","defs"],
+      srcWhy: "A no-clue exploratory question wants an encyclopedia or general search: orientation and vocabulary first." },
+    { q: "What is the test for when a school official may search a student\u2019s backpack?",
+      type: "Focusing", tell: "It asks for the specific governing test — the word \u201ctest\u201d is the tell. Focusing questions are the move from secondary to primary authority.",
+      srcKey: "prim", srcPool: ["prim","ency","dict"],
+      srcWhy: "A focusing question is answered by primary authority — reached through the secondary source that named it." },
+    { q: "Is a dog owner liable when the dog bites a guest who was teasing it?",
+      type: "Application", tell: "It asks how a rule operates on specific facts — a bite, a guest, teasing. Specific facts in the question are the tell for application.",
+      srcKey: "cases", srcPool: ["cases","survey","ency"],
+      srcWhy: "Fact-finding application: look for decided cases with similar facts." },
+    { q: "What does \u201cemployee\u201d mean under this state\u2019s wage statute?",
+      type: "Definitional", tell: "Still a what-does-X-mean question — but \u201cunder this statute\u201d signals precision is critical, which changes the source, not the type.",
+      srcKey: "defs", srcPool: ["defs","dict","ency"],
+      srcWhy: "When a definition must be precise \u2014 \u201cunder this statute\u201d \u2014 the statute\u2019s own definitions section answers it, not a dictionary." },
+    { q: "How do the fifty states handle recording a phone call?",
+      type: "Exploratory", tell: "It asks how many jurisdictions do what — the survey flavor of exploratory. \u201cThe fifty states\u201d is the tell.",
+      srcKey: "survey", srcPool: ["survey","treat","cases"],
+      srcWhy: "Survey questions point to the tools built jurisdiction-by-jurisdiction: ALR annotations, Restatements, 50-state surveys." },
+    { q: "What are the elements of adverse possession in Michigan?",
+      type: "Focusing", tell: "It asks for the specific governing rule — \u201cthe elements\u201d — in a named jurisdiction. That is a focusing question.",
+      srcKey: "prim", srcPool: ["prim","survey","dict"],
+      srcWhy: "Elements live in primary authority; a secondary source gets you to the leading Michigan statement, then you read the law itself." },
+    { q: "What is the overall structure of federal environmental regulation?",
+      type: "Exploratory", tell: "You know the area but need its structure — the foundational flavor of exploratory. \u201cOverall structure\u201d is the tell.",
+      srcKey: "treat", srcPool: ["treat","ency","prim"],
+      srcWhy: "A foundational question wants a treatise: the source organized to give a field\u2019s structure." },
+    { q: "Does taping the three-day notice to the door satisfy the statute\u2019s delivery requirement?",
+      type: "Application", tell: "A rule exists (the statute\u2019s delivery requirement); the question is whether these facts — tape, a door — satisfy it. Rule-plus-facts is application.",
+      srcKey: "cases", srcPool: ["cases","defs","ency"],
+      srcWhy: "Fact-finding application: courts that have ruled on similar delivery facts answer it." },
+    { q: "What does \u201ccurtilage\u201d mean?",
+      type: "Definitional", tell: "Pure what-does-the-word-mean. When the word is unfamiliar, the first move is a working definition.",
+      srcKey: "dict", srcPool: ["dict","treat","cases"],
+      srcWhy: "A dictionary or general search supplies the working definition and the vocabulary for the next question." },
+    { q: "What standard governs a court\u2019s decision to seal a settlement agreement?",
+      type: "Focusing", tell: "\u201cWhat standard governs\u201d asks for the specific rule — focusing, the move to primary authority.",
+      srcKey: "prim", srcPool: ["prim","ency","survey"],
+      srcWhy: "The standard is stated in primary authority; the secondary source is the road there, not the destination." },
+    { q: "What does the legal landscape look like for flying a drone over a neighbor\u2019s land?",
+      type: "Exploratory", tell: "The question literally asks for the landscape — exploratory, no-clue flavor, since no doctrine is presupposed.",
+      srcKey: "ency", srcPool: ["ency","cases","defs"],
+      srcWhy: "Orientation first: an encyclopedia or general search surfaces the areas in play and the terms of art." },
+    { q: "How does the rule against perpetuities apply to an option to purchase that renews every ten years?",
+      type: "Application", tell: "A known rule applied to unusual facts — and if no decision squarely addresses it, this becomes the constructive flavor: build the answer from what exists.",
+      srcKey: "build", srcPool: ["build","dict","ency"],
+      srcWhy: "Constructive application: when nothing is on point, assemble the rule from multiple sources and reason by analogy." },
+    { q: "Which states require every party\u2019s consent before a call may be recorded?",
+      type: "Exploratory", tell: "\u201cWhich states\u201d is a jurisdiction count — the survey flavor of exploratory, even though it sounds narrow.",
+      srcKey: "survey", srcPool: ["survey","prim","treat"],
+      srcWhy: "Jurisdiction-by-jurisdiction questions go to the survey tools; from there each state\u2019s rule is a focusing question." }
+  ];
+
+  var deck = document.getElementById("deck"),
+      score = document.getElementById("score"),
+      tally = document.getElementById("tally"),
+      fill  = document.getElementById("progfill"),
+      doneBox = document.getElementById("done");
+  var answered = 0, right = 0, total = BANK.length * 2; /* two moves per card */
+
+  function bump() {
+    answered++;
+    score.textContent = answered + " of " + total + " answered";
+    tally.textContent = right + " correct";
+    fill.style.width = Math.round(answered / total * 100) + "%";
+    if (answered === total) {
+      var pct = Math.round(right / total * 100);
+      doneBox.innerHTML = "<p class=\"qno\">All questions typed</p>" +
+        "<div class=\"big\">" + right + " / " + total + " (" + pct + "%)</div>" +
+        "<p>The diagnostic works in both directions: the type tells you where to look, and the source you find confirms you typed it right. Add a reflection below and download your record.</p>";
+      doneBox.classList.add("show");
+      if (window.ExportReflect) ExportReflect.log("Final score", right + " / " + total);
+    }
+  }
+
+  function stage(card, label, options, correctIdx, why, logLabel, colWrap) {
+    var head = el("p", { class: "stagehead" }, [label]);
+    var wrap = el("div", { class: "opts" + (colWrap ? " col" : ""), role: "group", "aria-label": label });
+    var fb = QM.live(el("div", { class: "fb" }));
+    fb.hidden = true;
+    var done = false;
+    options.forEach(function (o, i) {
+      var b = el("button", { class: "opt", type: "button" }, [o]);
+      b.addEventListener("click", function () {
+        if (done) return;
+        done = true;
+        var ok = i === correctIdx;
+        if (ok) right++;
+        wrap.querySelectorAll(".opt").forEach(function (x, xi) {
+          x.disabled = true;
+          if (xi === correctIdx) x.classList.add("good");
+          else if (xi === i) x.classList.add("bad");
+        });
+        fb.hidden = false;
+        fb.classList.add(ok ? "good" : "bad");
+        QM.announce(fb, (ok ? "Right. " : "Not quite. ") + why);
+        if (window.ExportReflect) ExportReflect.log(logLabel, ok ? "correct" : "incorrect \u2014 chose " + o);
+        bump();
+        if (card._next) { card._next(); card._next = null; }
+      });
+      wrap.appendChild(b);
+    });
+    return [head, wrap, fb];
+  }
+
+  BANK.forEach(function (item, n) {
+    var card = el("div", { class: "card" }, [
+      el("p", { class: "qno" }, ["Question " + (n + 1) + " of " + BANK.length]),
+      el("p", { class: "q" }, [item.q])
+    ]);
+    /* stage 1: the type */
+    var s1 = stage(card, "First move \u2014 name the type", TYPES,
+      TYPES.indexOf(item.type), item.tell,
+      "Q" + (n + 1) + " type (" + item.type + ")");
+    s1.forEach(function (x) { card.appendChild(x); });
+
+    /* stage 2: the source, revealed only after the type is answered */
+    card._next = function () {
+      var opts = item.srcPool.map(function (k) { return SRC[k]; });
+      var s2 = stage(card, "Second move \u2014 which source family answers it?", opts,
+        item.srcPool.indexOf(item.srcKey), item.srcWhy,
+        "Q" + (n + 1) + " source", true);
+      s2.forEach(function (x) { card.appendChild(x); });
+    };
+    deck.appendChild(card);
+  });
+
+  /* the shared Research Log follows the student between modules */
+  if (window.ResearchLog) ResearchLog.mount({ parent: document.getElementById("export-slot").parentNode,
+    before: document.getElementById("export-slot") });
+
+  if (window.ExportReflect) ExportReflect.mount(document.getElementById("export-slot"), {
+    module: "Type the Question",
+    chapter: "Chapter 3 \u2014 The Question Method",
+    intro: "Your classifications are collected locally as you work. Add a reflection and download the record to submit.",
+    prompts: [
+      "Which type was hardest to spot, and what tell will you watch for next time?",
+      "Write one research question of your own for each of the four types \u2014 about any legal topic you are curious about."
+    ]
+  });
+})();
+</script>
+</body>
+</html>
