+      return { t: t, good: i === goodIdx, fb: i === goodIdx ? fbGood : fbWrong[i] };
+    });
+  }
+  var CURRENCY = [
+    { head: "Catch", q: "You are working from the annual print CFR edition. <b>Which tool catches amendments made since that edition went to press?</b>",
+      opts: toolOpts(1,
+        "The LSA is the monthly record of exactly that: which CFR sections have changed since the last annual update.",
+        ["The eCFR would work if you were online \u2014 but the tool built to reconcile a print annual edition is the LSA.",
+         "", "The FR holds the amending documents, but the LSA is the index that tells you which sections were touched.",
+         "A citator tracks court treatment, not intervening amendments.",
+         "Agency sites are inconsistent about amendment history; the LSA is the systematic record."]) },
+    { head: "Catch", q: "A regulation still appears, word for word, in the CFR text \u2014 but a court struck it down last year. <b>Which tool catches that?</b>",
+      opts: toolOpts(3,
+        "Only a citator surfaces judicial treatment. A regulation invalidated by a court is no longer enforceable even though it still appears in the CFR text \u2014 this is the trap the citator exists to catch.",
+        ["The eCFR shows current codified text \u2014 and an invalidated rule can still sit in it.",
+         "The LSA tracks amendments to the text, not court decisions about it.",
+         "The FR would show an agency's response, if any \u2014 but the invalidation itself lives in case law.",
+         "", "The agency may note it eventually, but the systematic check is the citator."]) },
+    { head: "Catch", q: "You need the most current codified text available for free, with a note showing the date it is updated through. <b>Which tool?</b>",
+      opts: toolOpts(0,
+        "The eCFR is updated daily and carries an updated-through date on each title \u2014 the most current freely available source of codified text.",
+        ["", "The LSA supplements the annual edition; the eCFR simply is current.",
+         "The FR is the daily stream of documents, not consolidated codified text.",
+         "Citators judge validity, not currency of text.",
+         "Agency postings vary; the eCFR is the systematic current text."]) },
+    { head: "Catch", q: "The rule's text has not changed, but the agency has posted a compliance bulletin that changes how it enforces the rule in practice. <b>Which tool catches that?</b>",
+      opts: toolOpts(4,
+        "Agency websites carry the guidance, bulletins, and enforcement-policy changes that can shift how a regulation operates before its text is formally amended.",
+        ["The eCFR only shows the text \u2014 which, here, has not changed.",
+         "The LSA tracks text changes; there are none.",
+         "Some guidance appears in the FR, but compliance bulletins typically live on the agency's own site.",
+         "A citator tracks courts, not agency practice.", ""]) },
+    { head: "Catch", q: "You want to know whether a proposed or interim rule is already in motion that would affect your section. <b>Which tool?</b>",
+      opts: toolOpts(2,
+        "The Federal Register carries proposed rules, interim final rules, and final rules \u2014 plus the Unified Regulatory Agenda listing what agencies plan to do.",
+        ["The eCFR shows what is codified now, not what is proposed.",
+         "The LSA looks backward at completed changes.",
+         "", "Citators track courts, not rulemaking in motion.",
+         "The agency site may mention it, but the official record of proposals is the FR."]) }
+  ];
+  var curHost = document.getElementById("currency"),
+      tally2 = document.getElementById("tally2"),
+      cRight = 0, cDone = 0;
