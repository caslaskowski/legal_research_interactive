+<link rel="preload" href="../../assets/fonts/archivo-700.woff2" as="font" type="font/woff2" crossorigin>
+<link rel="stylesheet" href="../../assets/firebrand.css">
+<!--shell:head:end-->
+<style>
+  :root{
+    /* legacy names aliased to the shared firebrand tokens (single source) */
+    --panel-2:var(--paper-2);
+    --link:var(--flame); --link-hover:var(--flame-deep);
+    --oxblood:var(--flame); --oxblood-soft:#c44d44;
+    --amber:#7a5416; --amber-bg:#f1e3c2;
+    --green:#2f6d56; --green-bg:#dde9e2;
+    --red:#9a2a27; --red-bg:#f0dad8;
+    --serif:"Archivo","Helvetica Neue",Arial,sans-serif;
+    --display:"Archivo","Helvetica Neue",Arial,sans-serif;
+    --mono:"IBM Plex Mono",ui-monospace,monospace;
+    --shadow:0 1px 0 rgba(0,0,0,.04),0 8px 30px -18px rgba(40,30,10,.45);
+  }
+  *{box-sizing:border-box}
+  html,body{margin:0;height:100%}
+  body{
+    background:
+      radial-gradient(1100px 560px at 92% -10%, rgba(167,45,42,.05), transparent 62%) fixed,
+      var(--paper);
+    color:var(--ink); font-family:var(--serif); font-size:17px; line-height:1.6;
+    -webkit-font-smoothing:antialiased;
+  }
+  body::before{
+    content:""; position:fixed; inset:0; pointer-events:none; z-index:0; opacity:.5;
+    background-image:radial-gradient(rgba(60,60,55,.04) 1px, transparent 1px);
+    background-size:4px 4px;
+  }
+  .app{position:relative; z-index:1; min-height:100%; display:flex; flex-direction:column}
+  .skip{position:absolute; left:-9999px; top:0; background:var(--ink); color:var(--paper); padding:8px 14px; border-radius:0 0 6px 0; font-family:var(--mono); font-size:12px; z-index:60}
+  .skip:focus{left:0}
+
+  /* top bar */
+  header.bar{
+    display:flex; align-items:center; gap:18px; flex-wrap:wrap;
+    padding:14px 22px; border-bottom:1.5px solid var(--rule-strong);
+    background:linear-gradient(180deg,#f3f3f1,#e9e9e7);
+    box-shadow:var(--shadow);
+  }
+  .brand{display:flex; align-items:baseline; gap:11px; margin-right:auto}
+  .mark{font-family:var(--display); font-weight:600; font-size:23px; letter-spacing:.3px; color:var(--ink); line-height:1}
+  .mark .dot{color:var(--oxblood)}
+  .tagline{font-family:var(--mono); font-size:11px; color:var(--ink-faint); letter-spacing:.16em; text-transform:uppercase}
+  .allmod{font-family:var(--mono); font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--ink-soft); text-decoration:none; margin-left:14px}
+  .allmod:hover{color:var(--oxblood)}
+  .controls{display:flex; align-items:center; gap:10px; flex-wrap:wrap}
+  .seg{display:inline-flex; border:1.5px solid var(--rule-strong); border-radius:7px; overflow:hidden; background:var(--paper)}
+  .seg button{font-family:var(--mono); font-size:11.5px; letter-spacing:.06em; text-transform:uppercase; border:0; background:transparent; color:var(--ink-soft); padding:7px 12px; cursor:pointer}
+  .seg button.on{background:var(--ink); color:var(--paper)}
+  .btn{font-family:var(--mono); font-size:11.5px; letter-spacing:.05em; text-transform:uppercase; border:1.5px solid var(--rule-strong); background:var(--paper); color:var(--ink-soft); padding:7px 12px; border-radius:7px; cursor:pointer}
+  .btn:hover{border-color:var(--ink-soft); color:var(--ink)}
+  .btn.accent{border-color:var(--oxblood); color:var(--oxblood)}
+  .btn.accent:hover{background:var(--oxblood); color:var(--paper)}
+
+  /* stepper */
+  .stepper{display:flex; gap:0; border-bottom:1.5px solid var(--rule-strong); background:linear-gradient(180deg, rgba(236,228,210,.55), rgba(236,228,210,.12)); padding:0 14px; overflow-x:auto}
+  .stepper button{
+    font-family:var(--mono); font-size:11.5px; letter-spacing:.06em; text-transform:uppercase;
+    background:transparent; border:0; border-bottom:2.5px solid transparent; color:var(--ink-soft);
+    padding:14px 16px; cursor:pointer; white-space:nowrap; display:flex; gap:8px; align-items:center;
+  }
+  .stepper button .n{font-size:10px; color:var(--ink-faint)}
+  .stepper button:hover{color:var(--ink)}
+  .stepper button.active{color:var(--ink); border-bottom-color:var(--oxblood)}
+  .stepper button .ok{color:var(--green)}
+
+  /* doc */
+  main.doc{padding:34px clamp(20px,5vw,68px) 100px; overflow-y:auto; flex:1}
+  .docwrap{max-width:780px; margin:0 auto; animation:rise .32s ease both}
+  @keyframes rise{from{opacity:0; transform:translateY(8px)}to{opacity:1; transform:none}}
+  .kicker{font-family:var(--mono); font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:var(--oxblood); margin-bottom:10px}
+  h1{font-family:var(--display); font-weight:600; font-size:clamp(25px,3.3vw,34px); line-height:1.13; letter-spacing:-.01em; margin:0 0 6px}
+  h2{font-family:var(--display); font-weight:600; font-size:20px; margin:30px 0 8px}
+  .sub{font-family:var(--mono); font-size:12px; color:var(--ink-faint); margin-bottom:24px; padding-bottom:18px; border-bottom:1px solid var(--rule)}
+  p{margin:0 0 16px}
+
+  .scenario{background:var(--panel); border:1px solid var(--rule); border-left:3px solid var(--oxblood); padding:18px 22px; border-radius:4px; margin:0 0 26px}
+  .scenario .h{font-family:var(--mono); font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--oxblood); margin-bottom:6px}
+
+  /* chain trail */
+  .trail{margin:0 0 22px}
+  .trailrow{display:flex; gap:12px; align-items:baseline; padding:8px 0; border-bottom:1px dashed var(--rule)}
+  .trailrow .tick{color:var(--green); font-family:var(--mono); font-size:13px; min-width:26px}
+  .trailrow .qt{flex:1}
+  .trailrow .qt b{font-weight:600}
+  .trailrow .qtype{font-family:var(--mono); font-size:10px; letter-spacing:.06em; text-transform:uppercase; color:var(--ink-faint)}
+
+  /* active step */
+  .qcard{border:1px solid var(--rule-strong); border-radius:10px; padding:22px 24px; background:var(--paper); box-shadow:var(--shadow); margin:0 0 22px}
+  .qcard .lab{font-family:var(--mono); font-size:10.5px; letter-spacing:.14em; text-transform:uppercase; color:var(--ink-faint); margin-bottom:6px}
+  .qcard .qtext{font-family:var(--display); font-weight:600; font-size:19px; line-height:1.3; margin:0 0 4px}
+  .qcard .qtype-pill{display:inline-block; font-family:var(--mono); font-size:10px; letter-spacing:.06em; text-transform:uppercase; color:var(--amber); background:var(--amber-bg); padding:2px 8px; border-radius:20px; margin-bottom:14px}
+  .answer{border-left:3px solid var(--ink-soft); background:var(--panel); padding:12px 16px; border-radius:0 6px 6px 0; margin:0 0 8px; font-size:15.5px}
+  .answer .h{font-family:var(--mono); font-size:10.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:4px}
+
+  .note{display:none; border:1px dashed var(--green); background:var(--green-bg); border-radius:8px; padding:12px 16px; margin:10px 0 0; font-size:14.5px}
+  body.guided .note{display:block; animation:rise .3s ease both}
+  .note .h{font-family:var(--mono); font-size:10.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--green); margin-bottom:4px}
+
+  .choices{margin:18px 0 0; display:flex; flex-direction:column; gap:10px}
+  .choice{display:flex; gap:12px; align-items:flex-start; text-align:left; width:100%; font:inherit; color:var(--ink); cursor:pointer;
+    border:1.5px solid var(--rule-strong); background:var(--paper); border-radius:9px; padding:13px 16px; line-height:1.4}
+  .choice:hover{border-color:var(--ink-soft)}
+  .choice .pick{font-family:var(--mono); font-size:12px; color:var(--ink-faint); min-width:20px; font-weight:600}
+  .choice.correct{border-color:var(--green); background:var(--green-bg)}
+  .choice.wrong{border-color:var(--red); background:var(--red-bg)}
+  .choice[disabled]{cursor:default; opacity:.95}
+  .fb{margin:8px 0 0; padding:12px 16px; border-radius:8px; font-size:14.5px; display:none}
+  .fb.show{display:block; animation:rise .25s ease both}
+  .fb.good{border:1px solid var(--green); background:var(--green-bg)}
+  .fb.bad{border:1px solid var(--red); background:var(--red-bg)}
+  .fb .tag{font-family:var(--mono); font-size:10px; letter-spacing:.1em; text-transform:uppercase; padding:2px 8px; border-radius:20px; margin-bottom:6px; display:inline-block}
+  .fb.good .tag{background:#cfe2d8; color:var(--green)}
