+  var PARTS = {
+    finding: ["Finding aids", "<p>The table of contents path and the section heading are how you locate the right discussion inside a long work. Learning to navigate them quickly is half the skill of using treatises and encyclopedias well — you jump to the section your question needs, you do not read from page one.</p>"],
+    narrative: ["The narrative text", "<p>The author's explanation of the doctrine: how the area is structured, what the elements and tests are, where the debates lie, and which terms of art you need. This is what orients you and supplies the vocabulary your later questions will require. Notice what this passage just handed you: the phrase <i>duty of habitability</i> and the <i>reasonable time</i> standard — terms you could not have put in a question before reading it.</p>"],
+    footnotes: ["Footnotes and citations", "<p>The most valuable part for a researcher. The footnotes point to the primary authority the narrative is describing — a single well-placed footnote can hand you the leading case on your issue. Read the one that answers the question you are holding <em>now</em>; log the rest as later questions with their citations noted.</p>"],
+    currency: ["Currency and supplementation", "<p>Print treatises and encyclopedias update through pocket parts and supplements; online versions show a &ldquo;current through&rdquo; date. Knowing how a source updates — and when it last did — tells you how far to trust it before you verify against primary authority.</p>"],
+    apparatus: ["Editorial apparatus", "<p>Cross-references to related sections, research references to other secondary sources, and (in annotated works like ALR) summaries organized by jurisdiction or factual scenario. This is the machinery that turns one useful section into a doorway to the rest of the landscape — including the remedies section your <em>next</em> question will need.</p>"]
+  };
+  var seen = {}, total = 5;
+  var title = document.getElementById("ex-title"),
+      body  = document.getElementById("ex-body"),
+      count = document.getElementById("ex-seen");
+
+  document.querySelectorAll(".hot[data-part]").forEach(function(b){
+    b.addEventListener("click", function(){
+      document.querySelectorAll(".hot[data-part]").forEach(function(x){ x.setAttribute("aria-expanded","false"); });
+      b.setAttribute("aria-expanded","true");
+      var k = b.getAttribute("data-part"), P = PARTS[k];
+      title.textContent = P[0];
+      body.innerHTML = P[1];
+      if (!seen[k]) {
+        seen[k] = true;
+        if (window.ExportReflect) ExportReflect.log("Explored component", P[0]);
+      }
+      count.textContent = "Explored " + Object.keys(seen).length + " of " + total + " components";
+      if (Object.keys(seen).length === total && window.ExportReflect)
+        ExportReflect.log("Anatomy complete", "all five components explored");
+    });
+  });
+
+  /* knowledge check: match source type to question type */
+  var OPTS = [
+    { t: "A legal encyclopedia", good: false,
+      fb: "An encyclopedia orients a no-clue exploratory question — what the landscape looks like. This question already has the landscape; it asks how many jurisdictions do what. Reach for the survey tools." },
+    { t: "An ALR annotation or 50-state survey", good: true,
+      fb: "Right. A jurisdiction-by-jurisdiction question is a survey question, and ALR annotations, Restatements, and 50-state surveys are built to answer exactly that shape of question." },
+    { t: "A treatise on landlord–tenant law", good: false,
+      fb: "A treatise answers a foundational question — the structure of an area you already know you are in. It will discuss the duty, but it is not organized to count jurisdictions. The survey tools are." },
+    { t: "A law review article", good: false,
+      fb: "A law review article argues a thesis; it may collect authority along the way, but it is not built to survey jurisdictions systematically. ALR annotations and 50-state surveys are." }
+  ];
+  var wrap = document.getElementById("kc-opts"), fb = document.getElementById("kc-fb"), done = false;
+  OPTS.forEach(function(o){
+    var b = QM.el("button", { class: "opt", type: "button" }, [o.t]);
+    b.addEventListener("click", function(){
+      if (done) return;
+      done = true;
+      wrap.querySelectorAll(".opt").forEach(function(x){ x.disabled = true; });
+      b.classList.add(o.good ? "good" : "bad");
+      if (!o.good) wrap.querySelectorAll(".opt").forEach(function(x, i){ if (OPTS[i].good) x.classList.add("good"); });
+      QM.announce(fb, o.fb);
+      if (window.ExportReflect) ExportReflect.log("Knowledge check: survey question source",
+        (o.good ? "correct" : "incorrect \u2014 chose " + o.t));
+    });
+    wrap.appendChild(b);
+  });
+
+  if (window.ExportReflect) ExportReflect.mount(document.getElementById("export-slot"), {
+    module: "How to Read a Secondary Source (Appendix A)",
+    chapter: "Chapter 4 \u2014 Secondary Sources / Appendix A",
+    intro: "Your exploration is collected locally as you click. Add a reflection and download the record to submit.",
+    prompts: [
+      "Which component of a secondary source do you expect to lean on most in your next research problem, and why?",
+      "The narrative handed you two terms of art you did not bring to the page. Write the next research question those terms make possible."
+    ]
+  });
+})();
+</script>
+</body>
+</html>
