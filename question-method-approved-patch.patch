+.modnav-crumb a:hover, .modnav-crumb a:focus-visible{ text-decoration: underline; }
+.modnav-verified{ font-size: .85rem; color: var(--ink-soft); margin: 0 0 10px; }
+.modnav-links{ display: flex; justify-content: space-between; gap: 14px; flex-wrap: wrap;
+  padding: 6px 0 22px; }
+.modnav-link{ display: flex; flex-direction: column; gap: 2px; text-decoration: none;
+  color: var(--ink); padding: 10px 12px; border: 1px solid var(--rule-strong);
+  border-radius: 8px; background: var(--panel); max-width: 46%; }
+.modnav-link:hover{ border-color: var(--flame); }
+.modnav-link:focus-visible{ outline: 3px solid var(--flame); outline-offset: 2px; }
+.modnav-link .dir{ font-family: var(--mono); font-size: .68rem; letter-spacing: .1em;
+  text-transform: uppercase; color: var(--flame); }
+.modnav-link .t{ font-weight: 600; font-size: .92rem; }
+.modnav-link.next{ margin-left: auto; text-align: right; }
+
+/* ---- local-storage disclosure (js/lib.js) --------------------------------- */
+.storage-note{ display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
+  max-width: var(--maxw); margin: 18px auto 0; padding: 10px 28px; font-size: .85rem;
+  color: var(--ink-soft); }
+.storage-note button{ font: inherit; font-size: .8rem; color: var(--flame);
+  background: none; border: 1px solid var(--rule-strong); border-radius: 6px;
+  padding: 4px 10px; cursor: pointer; }
+.storage-note button:hover{ border-color: var(--flame); }
+.storage-note button:focus-visible{ outline: 3px solid var(--flame); outline-offset: 2px; }
