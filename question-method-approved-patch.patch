+          if (answered === BANK.length) {
+            var pct = Math.round(right / BANK.length * 100);
+            doneBox.innerHTML = "<p class=\"qno\">Pass complete</p><div class=\"big\">" + right + " / " + BANK.length + " (" + pct + "%)</div>" +
+              "<p>Interleaving is spaced practice's partner: come back in a few days and the deck will be reshuffled. The feedback on anything you missed names the chapter to revisit.</p>";
+            doneBox.classList.add("show");
+            if (window.ExportReflect) ExportReflect.log("Pass complete", right + " / " + BANK.length);
+          }
+        });
+        wrap.appendChild(b);
+      });
+      card.appendChild(wrap); card.appendChild(fb);
+      deck.appendChild(card);
+    });
+  }
+  document.getElementById("reshuffle").addEventListener("click", function () {
+    if (answered === 0 || answered === BANK.length ||
+        window.confirm("Reshuffle now? Your progress on this pass resets (answers already logged stay in your record).")) render();
+  });
+  render();
+
+  /* the shared Research Log follows the student between modules */
+  if (window.ResearchLog) ResearchLog.mount({ parent: document.getElementById("export-slot").parentNode,
+    before: document.getElementById("export-slot") });
+
+  if (window.ExportReflect) ExportReflect.mount(document.getElementById("export-slot"), {
+    module: "Mixed Review \u2014 The Diagnostic Moves",
+    chapter: "Chapter 9 \u2014 Narrowing and Closing Out Your Research (cumulative, Ch. 1\u20139)",
+    intro: "Every answer is collected locally, including across reshuffles. Add a reflection and download the record to submit.",
+    prompts: [
+      "Which skill's items did you recognize slowest, and which chapter will you revisit first?",
+      "Interleaving forces you to name the move before making it. Where in a real research project does that same recognition step happen?"
+    ]
+  });
+})();
+</script>
+</body>
+</html>
