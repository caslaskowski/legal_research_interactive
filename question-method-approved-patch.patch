+<script src="../../js/lib.js"></script>
+<script>
+(function(){
+  "use strict";
+  var KEY = "qmflash_v1";
+  var TERMS = [
+    ["ALR annotation","An article in American Law Reports collecting and analyzing the case law of many jurisdictions on a narrow legal issue; a primary tool for survey questions."],
+    ["analytical closure","The judgment that research is complete because every question has been answered or identified as genuinely open, the rule and its application are covered, and further research would only refine wording."],
+    ["annotated code","A statutory code enhanced with editorial notes: case annotations, cross-references to regulations and secondary sources, and history notes."],
+    ["annotated outline","The running document that records the product of research: each question's synthesized answer, organized under the structure the final document will take."],
+    ["application question","A question asking how a rule operates on specific facts, answered by locating cases with similar facts (fact-finding) or by building the rule from multiple sources when nothing is on point (constructive application)."],
+    ["authority note","The note accompanying a CFR part that cites the statute empowering the agency to issue it."],
+    ["binding authority","Law a court must follow: the constitution, statutes, and regulations of its own jurisdiction, the decisions of higher courts in its own system, and federal law applicable within it."],
+    ["canons of construction","Established interpretive principles courts use to read ambiguous statutory text, such as the plain meaning rule, expressio unius, ejusdem generis, and the rule against surplusage."],
+    ["citator","A tool (KeyCite or Shepard's) that tracks an authority's subsequent history and treatment, showing whether it remains good law."],
+    ["code","Statutes arranged by subject as currently amended, in an official or annotated compilation."],
+    ["committee report","The report accompanying a bill out of committee; generally the most authoritative legislative history document."],
+    ["common law","Judge-made law developed case by case through judicial decision."],
+    ["constructive application","Answering an application question no decision squarely addresses by building the rule from the cases that exist and reasoning by analogy."],
+    ["definitional question","A question asking what a word or phrase means, answered by a dictionary for a working definition or by the statute's definitions section, a regulation, or case law when precision is critical."],
+    ["dictum","A statement in an opinion not necessary to the decision; persuasive at most, never binding."],
+    ["dispositive facts","The facts a decision actually turned on; identifying them is the key skill for predicting how a case applies to new facts."],
+    ["docket","The court's running record of a litigation: every filing, order, and event, in order."],
+    ["exploratory question","A question asking what the legal landscape looks like, answered by an encyclopedia or general search (no-clue), a treatise (foundational), or ALRs, Restatements, and 50-state surveys (survey)."],
+    ["Federal Register","The daily federal publication of proposed and final rules, notices, and presidential documents."],
+    ["focusing question","A question asking what the specific governing rule, standard, or test is; the move from secondary to primary authority."],
+    ["guidance document","Agency material, such as manuals, opinion letters, and policy statements, that explains the agency's interpretation without the force of law."],
+    ["hallucination","A generative AI output that is plausible but fabricated, including invented citations, quotations, and holdings."],
+    ["headnote","An editor-written summary of a single point of law in an opinion; a research tool, not authority."],
+    ["holding","The court's resolution of the issue necessary to its decision; the portion of an opinion carrying precedential weight."],
+    ["hornbook","A one-volume treatise summarizing an area of law, written primarily for students."],
+    ["legislative history","The documents produced as a bill moves through the legislature, used to uncover legislative intent when statutory text is ambiguous."],
+    ["List of CFR Sections Affected (LSA)","The monthly record of which CFR sections have changed since the last annual update."],
+    ["Notice of Proposed Rulemaking (NPRM)","The Federal Register notice proposing a rule and opening the public comment period; the record of the agency's intent."],
+    ["persuasive authority","Authority a court may consider but need not follow: primary authority from other jurisdictions, lower or coordinate courts, secondary sources, and dicta."],
+    ["practical closure","Stopping research because an external limit, a deadline, a budget, or an instruction, forces the stop, with what remains documented."],
+    ["preemption","Federal law displacing state law in areas where Congress has constitutional power, either expressly or impliedly. In scholarship, preemption research instead means checking whether your argument has already been made."],
+    ["primary authority","The law itself: constitutions, statutes, regulations, case law, and treaties."],
+    ["Question Method","The research method this book teaches: write a single research question, research it, record the answer scoped to that question, and let the answer produce the next question, repeating until closure."],
+    ["research closure","The professional judgment that research is good enough for its purpose; it comes in analytical and practical forms."],
+    ["Research Log","The running record of the research process: each question, its type, the source consulted, the scoped answer, the citation, and the next question."],
+    ["Restatement","The American Law Institute's synthesis of common-law rules in an area; among the most persuasive secondary authorities."],
+    ["root expander","The search operator (!) that retrieves every word sharing a root, such as negligen! for negligent, negligence, and negligently."],
+    ["secondary source","Material about the law, such as encyclopedias, treatises, ALR annotations, and law review articles, used to find and understand primary authority but rarely cited as law."],
+    ["session laws","Laws as enacted, published in chronological order, such as the United States Statutes at Large."],
+    ["single-source trap","A long run of Research Log entries in one source type with the question still only partly answered; the log-visible signal to switch sources."],
+    ["slip law","The first official publication of a newly enacted statute, issued as a standalone document."],
+    ["source note","The note citing the Federal Register document that created or last amended a CFR part; the thread you pull to reach the preamble."],
+    ["stare decisis","The doctrine that courts stand by precedent: their own prior decisions and those of the courts above them."],
+    ["terms and connectors","The precision search mode built from Boolean operators, proximity connectors, expanders, and phrase searching."],
+    ["treatise","A comprehensive scholarly treatment of a single area of law, often multivolume, organized to give the field's structure."]
+  ];
+
+  /* ---- state: { order:[idx...], pos:n, got:{idx:true}, again:{idx:count} } ---- */
+  var state = null;
+  function freshState(shuffled) {
+    var order = TERMS.map(function(_, i){ return i; });
+    if (shuffled) for (var i = order.length - 1; i > 0; i--) {
+      var j = Math.floor(Math.random() * (i + 1)), t = order[i]; order[i] = order[j]; order[j] = t;
+    }
+    return { v: 1, order: order, pos: 0, got: {}, again: {}, restarts: 0, saved: new Date().toISOString() };
+  }
+  function load() {
+    try {
+      var raw = localStorage.getItem(KEY);
+      if (raw) { var s = JSON.parse(raw); if (s && s.v === 1 && Array.isArray(s.order)) return s; }
+    } catch (e) {}
+    return freshState(true);
+  }
+  function save() {
+    state.saved = new Date().toISOString();
+    try { localStorage.setItem(KEY, JSON.stringify(state)); } catch (e) {}
+  }
+
+  var faceEl = document.getElementById("face"), sideEl = document.getElementById("side"),
+      cardEl = document.getElementById("fcard"), counts = document.getElementById("counts"),
+      fill = document.getElementById("progfill"), announce = document.getElementById("announce");
+  var flipBtn = document.getElementById("flipBtn"), gotBtn = document.getElementById("gotBtn"),
+      againBtn = document.getElementById("againBtn");
+  var showingDef = false;
+
+  function remaining() {
+    return state.order.filter(function (idx) { return !state.got[idx]; });
+  }
+  function currentIdx() {
+    var rem = remaining();
+    if (!rem.length) return null;
+    if (state.pos >= rem.length) state.pos = 0;
+    return rem[state.pos];
+  }
+  function render(announceText) {
+    var gotN = Object.keys(state.got).length, rem = remaining();
+    counts.textContent = gotN + " of " + TERMS.length + " retired \u00b7 " + rem.length + " to go";
+    fill.style.width = Math.round(gotN / TERMS.length * 100) + "%";
+    var idx = currentIdx();
+    if (idx === null) {
+      cardEl.innerHTML = "<div class=\"donebox\"><p class=\"side\">Deck complete</p>" +
+        "<div class=\"big\">" + TERMS.length + " / " + TERMS.length + "</div>" +
+        "<p>Every term retired. Restart the deck for another pass \u2014 the terms you marked \u201cAgain\u201d most often are the ones to revisit in the chapters.</p></div>";
+      flipBtn.disabled = gotBtn.disabled = againBtn.disabled = true;
+      return;
+    }
+    flipBtn.disabled = false;
+    gotBtn.disabled = againBtn.disabled = !showingDef;
+    sideEl.textContent = showingDef ? "Definition" : "Term";
+    faceEl.className = showingDef ? "def" : "term";
+    faceEl.textContent = showingDef ? TERMS[idx][1] : TERMS[idx][0];
+    if (!cardEl.contains(sideEl)) { cardEl.innerHTML = ""; cardEl.appendChild(sideEl); cardEl.appendChild(faceEl); }
+    flipBtn.setAttribute("aria-pressed", String(showingDef));
+    if (announceText) QM.announce(announce, announceText);
+  }
+
+  function flip() {
+    if (currentIdx() === null) return;
+    showingDef = !showingDef;
+    render(showingDef ? "Definition shown" : "Term shown");
+  }
+  function mark(got) {
+    var idx = currentIdx();
+    if (idx === null || !showingDef) return;
+    if (got) { state.got[idx] = true; }
+    else {
+      state.again[idx] = (state.again[idx] || 0) + 1;
+      state.pos++; /* card goes to the back of the remaining pile */
+    }
+    showingDef = false;
+    save();
+    render(got ? "Marked got it. Next card." : "Marked again \u2014 it will come back. Next card.");
+  }
+
+  flipBtn.addEventListener("click", flip);
+  gotBtn.addEventListener("click", function(){ mark(true); });
+  againBtn.addEventListener("click", function(){ mark(false); });
+  document.addEventListener("keydown", function (e) {
+    if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
+    if (e.key === " ") { e.preventDefault(); flip(); }
+    else if (e.key === "ArrowRight") { mark(true); }
+    else if (e.key === "ArrowLeft") { mark(false); }
+  });
+  document.getElementById("shuffleBtn").addEventListener("click", function () {
+    var rem = remaining();
+    for (var i = state.order.length - 1; i > 0; i--) {
+      var j = Math.floor(Math.random() * (i + 1)), t = state.order[i];
+      state.order[i] = state.order[j]; state.order[j] = t;
+    }
+    state.pos = 0; showingDef = false; save(); render("Deck shuffled \u2014 " + rem.length + " cards remaining");
+  });
+  document.getElementById("restartBtn").addEventListener("click", function () {
+    if (!window.confirm("Restart the deck? Your got-it marks will be cleared. Again counts and the restart tally are kept for your study record.")) return;
+    var keepAgain = state.again, restarts = (state.restarts || 0) + 1;
+    state = freshState(true); state.again = keepAgain; state.restarts = restarts;
+    showingDef = false; save(); render("Deck restarted");
+  });
+
+  /* ---- the turn-in study record (.txt) ---- */
+  document.getElementById("recordBtn").addEventListener("click", function () {
+    var bar = new Array(63).join("=");
+    var gotN = Object.keys(state.got).length;
+    var hard = Object.keys(state.again).map(function (k) {
+      return { t: TERMS[+k][0], n: state.again[k] };
+    }).sort(function (a, b) { return b.n - a.n; }).slice(0, 8);
+    var L = [bar, "GLOSSARY FLASHCARDS \u2014 STUDY RECORD", bar,
+      "Date: " + new Date().toLocaleString(), "",
+      "Terms retired this pass: " + gotN + " of " + TERMS.length,
+      "Deck restarts (additional passes): " + (state.restarts || 0), ""];
+    L.push("TERMS MARKED \u201cAGAIN\u201d MOST (revisit these in the chapters)");
+    L.push(new Array(43).join("-"));
+    if (!hard.length) L.push("  (none \u2014 every term retired on first sight)");
+    hard.forEach(function (h) { L.push("  " + h.t + "  \u2014 marked Again " + h.n + (h.n === 1 ? " time" : " times")); });
+    L.push("");
+    var refl = document.getElementById("fc-reflect").value.trim();
+    L.push("REFLECTION");
+    L.push(new Array(43).join("-"));
+    L.push(refl ? refl : "  (no reflection entered)");
+    L.push("");
+    L.push("Generated locally in the student's browser \u2014 no data was sent anywhere.");
+    var blob = new Blob([L.join("\n")], { type: "text/plain" });
+    var a = document.createElement("a");
+    a.href = URL.createObjectURL(blob);
+    a.download = "glossary-study-record.txt";
+    document.body.appendChild(a); a.click();
+    setTimeout(function(){ URL.revokeObjectURL(a.href); a.remove(); }, 0);
+    QM.announce(announce, "Study record downloaded");
+  });
+
+  /* ---- download / re-load progress (survives cleared browser data) ---- */
+  document.getElementById("exportBtn").addEventListener("click", function () {
+    var blob = new Blob([JSON.stringify(state, null, 2)], { type: "application/json" });
+    var a = document.createElement("a");
+    a.href = URL.createObjectURL(blob);
+    a.download = "glossary-flashcards-progress.json";
+    document.body.appendChild(a); a.click();
+    setTimeout(function(){ URL.revokeObjectURL(a.href); a.remove(); }, 0);
+    QM.announce(announce, "Progress file downloaded");
+  });
+  document.getElementById("importFile").addEventListener("change", function (e) {
+    var f = e.target.files && e.target.files[0];
+    if (!f) return;
+    var r = new FileReader();
+    r.onload = function () {
+      try {
+        var s = JSON.parse(r.result);
+        if (!s || s.v !== 1 || !Array.isArray(s.order)) throw new Error("bad file");
+        state = s; showingDef = false; save();
+        render("Progress file loaded \u2014 " + remaining().length + " cards remaining");
+      } catch (err) {
+        QM.announce(announce, "That file does not look like a flashcards progress file.");
+      }
+      e.target.value = "";
+    };
+    r.readAsText(f);
+  });
+
+  state = load();
+  render();
+  QM.storageNotice({ keys: [KEY], parent: document.querySelector(".pagewrap") });
+})();
+</script>
