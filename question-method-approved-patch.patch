+          { t: "Before suing an Arizona public entity, a claimant must serve a notice of claim stating a specific amount for which the claim can be settled and the facts supporting that amount. A.R.S. § 12-821.01(A).", sample:"What does Arizona require before a person can sue a public entity?" },
+          { t: "The requirement exists to give the government entity an opportunity to investigate the claim, assess its potential liability, settle before litigation, and budget and plan. <em>Havasupai Tribe v. ABOR.</em>", sample:"Why does Arizona require the notice to state a specific amount — what is the purpose of the rule?" },
+          { t: "An offer to \u201caccept the sum of $450,000 as full and final settlement\u201d states a definite and exact amount and satisfies the requirement, even when the notice is directed at more than one public entity. <em>Donovan v. Yavapai CCCD.</em>", sample:"What kind of statement counts as a \u201cspecific amount\u201d and satisfies the requirement?" },
+          { t: "Qualifying, open-ended figures — amounts introduced by \u201capproximately,\u201d \u201cno less than,\u201d or \u201cin excess of\u201d — make the settlement amount impossible to ascertain and defeat the requirement, barring the action. <em>Deer Valley v. Houser.</em>", sample:"What kind of language fails the specific-amount requirement?" }
+        ]
+      }
+    ],
+    reflection: [
+      { q:"In the forward drill, which wrong next-question was most tempting to you — and what habit of thinking did it reveal (jumping ahead, naming a rule before you'd found it, chasing facts before the law told you which mattered, assuming the conclusion)?" },
+      { q:"In the reverse drill, how often was your question \u201cthe same idea in different words\u201d versus genuinely different from the sample? Where it was truly different, was one version better scoped — and why?" },
+      { q:"The Question Method asks you to write every question explicitly, even obvious ones. Where in these drills did you feel the urge to skip a step an expert would skip — and why is skipping risky for you right now?" },
+      { q:"Name one thing you will do differently in your next research session." }
+    ]
+  };
+
+  /* ---------- resilient storage ---------- */
+  const mem = {};
+  const store = {
+    get(k){ try{ const v=sessionStorage.getItem(k); return v===null?(k in mem?mem[k]:null):v; }catch(e){ return k in mem?mem[k]:null; } },
+    set(k,v){ try{ sessionStorage.setItem(k,v); }catch(e){ mem[k]=v; } }
+  };
+  function load(k,d){ try{ const v=store.get(k); return v?JSON.parse(v):d; }catch(e){ return d; } }
+  function save(k,v){ store.set(k,JSON.stringify(v)); }
+
+  /* ---------- state ---------- */
+  let mode  = store.get("lc_mode") || "guided";
+  if(mode!=="open" && mode!=="guided") mode="guided";
+  let stage = parseInt(store.get("lc_stage")||"0",10) || 0;
+  // forward: per-step record of attempt tags in order; and how far unlocked
+  let branch = load("lc_branch", { attempts: C.steps.map(()=>[]), solved: C.steps.map(()=>false) });
+  let unlocked = branch.solved.filter(Boolean).length; // index of active step
+  // reverse: keyed answers
+  let rev      = load("lc_rev", {});       // {p#u#:{q,rate}}
+  let revShown = load("lc_revShown", {});  // {p#:true}
+  let revNote  = load("lc_revNote", {});   // {p#:note}
+  let reflect  = load("lc_reflect", {});
+
+  const main = document.getElementById("main");
+  const stepper = document.getElementById("stepper");
+  const STAGES = ["Forward Drill","Reverse Drill","Reflection & Export"];
+
+  function esc(s){ return String(s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;"); }
+  function stageDone(i){
+    if(i===0) return branch.solved.every(Boolean);
+    if(i===1) return C.reverse.every((p,pi)=>p.units.every((u,ui)=> (rev["p"+pi+"u"+ui]||{}).q));
+    return false;
+  }
+
+  function buildStepper(){
+    stepper.innerHTML = STAGES.map((s,i)=>
+      `<button data-stage="${i}" class="${i===stage?'active':''}">
+         <span class="n">${i+1}</span>${s}${stageDone(i)?'<span class="ok">✓</span>':''}
+       </button>`).join("");
+  }
+
+  /* ---------- FORWARD ---------- */
+  function renderForward(){
+    let html = `<div class="kicker">Stage 1 · Forward Drill</div>
+      <h1>Follow the answer to the next question</h1>
+      <div class="sub">Each answer below is scoped to the question above it. Choose the next question that answer actually produces. Wrong turns are diagnosed, not just marked — read them.</div>
+      <div class="scenario"><div class="h">The problem</div>${C.scenario}</div>`;
+
+    // trail of solved questions
+    const solvedCount = branch.solved.filter(Boolean).length;
+    if(solvedCount>0){
+      html += `<div class="trail"><h2>Your chain so far</h2>`;
+      C.steps.forEach((st,i)=>{
+        if(branch.solved[i]){
+          html += `<div class="trailrow"><span class="tick">Q${i+1} ✓</span>
+            <span class="qt"><b>${st.q}</b><br><span class="qtype">${st.qtype}</span></span></div>`;
+        }
+      });
+      html += `</div>`;
+    }
+
+    if(unlocked < C.steps.length){
+      const i = unlocked;
+      const st = C.steps[i];
+      html += `<div class="qcard">
+        <div class="lab">Question ${i+1} · given</div>
+        <div class="qtext">${st.q}</div>
+        <span class="qtype-pill">${st.qtype}</span>
+        <div class="answer"><div class="h">Answer (scoped to this question)</div>${st.answer}</div>
+        <div class="note"><div class="h">▸ Researcher's note</div>${st.note}</div>
+        <div class="lab" style="margin-top:18px">What is the next question?</div>
+        <div class="choices" id="choices"></div>
+        <div class="advance" id="advance"></div>
+      </div>`;
+    } else {
+      html += `<div class="done-card"><div class="h">Forward drill complete</div>
+        You worked the chain from a no-clue exploratory question down to a precise application question — and past a case (<em>Kennedy</em>) that sat in the right area but answered the wrong issue. Your missteps are saved to your submission so you can see which habits to watch. Move on to the <strong>Reverse Drill</strong>.</div>`;
+    }
+    main.innerHTML = `<div class="docwrap">${html}</div>`;
+
+    if(unlocked < C.steps.length){
+      renderChoices(unlocked);
+    }
+  }
+
+  function renderChoices(i){
+    const st = C.steps[i];
+    const box = document.getElementById("choices");
+    const picked = branch.attempts[i] || [];
+    box.innerHTML = st.choices.map((c,ci)=>{
+      const wasWrong = picked.includes(ci) && !c.correct;
+      const wasRight = picked.includes(ci) && c.correct;
+      const cls = wasRight ? "correct" : (wasWrong ? "wrong" : "");
+      const dis = (wasWrong||wasRight) ? "disabled" : "";
+      return `<button class="choice ${cls}" data-ci="${ci}" ${dis}>
+        <span class="pick">${String.fromCharCode(65+ci)}</span>
+        <span>${c.t}</span>
+      </button>
+      <div class="fb ${c.correct?'good':'bad'} ${(wasWrong||wasRight)?'show':''}" role="status" aria-live="polite" id="fb${ci}">
+        <span class="tag">${wasRight?'On the path':esc(c.tag)}</span><div>${c.fb}</div>
+      </div>`;
+    }).join("");
+
+    box.querySelectorAll(".choice").forEach(b=>{
+      b.addEventListener("click",()=>{
+        const ci = +b.dataset.ci;
+        const c = st.choices[ci];
+        if(!branch.attempts[i].includes(ci)) branch.attempts[i].push(ci);
+        if(c.correct){ branch.solved[i]=true; }
+        save("lc_branch", branch);
+        unlocked = branch.solved.filter(Boolean).length;
+        renderForward();
+        buildStepper();
+        if(c.correct){
+          const adv = document.getElementById("advance");
+          if(adv){
+            adv.innerHTML = (unlocked<C.steps.length)
+              ? `<button class="btn accent" id="nextStep">Continue to Question ${unlocked+1} ▸</button>`
+              : ``;
+            const ns = document.getElementById("nextStep");
+            if(ns) ns.onclick = ()=>{ window.scrollTo({top:0,behavior:"smooth"}); };
+          }
+        }
+      });
+    });
+  }
+
+  /* ---------- REVERSE ---------- */
+  function renderReverse(){
+    let html = `<div class="kicker">Stage 2 · Reverse Drill</div>
+      <h1>Work the chain backward</h1>
+      <div class="sub">Each finished paragraph is a chain of answers. For every numbered unit, write the research question whose answer that unit supplies — then compare with a sample and judge the difference honestly.</div>
+      <div class="callout"><span class="h">Do this part on paper first</span>Write your question for each unit before revealing the sample. The point is not to match the sample — it is to notice whether your version is the <em>same idea in different words</em> or <em>truly different</em>, and if truly different, which is better scoped.</div>`;
+
+    C.reverse.forEach((p,pi)=>{
+      const shown = !!revShown["p"+pi];
+      html += `<div class="para"><h2>${p.title}</h2><div class="pcite">${p.cite}</div>`;
+      p.units.forEach((u,ui)=>{
+        const key="p"+pi+"u"+ui;
+        const cur = rev[key]||{};
+        html += `<div class="unit">
+          <div class="utext"><span class="unum">Unit ${ui+1}</span>${u.t}</div>
+          <label class="qlab" for="${key}">Your question</label>
+          <textarea id="${key}" data-rev="${key}" placeholder="Write the question this unit answers…">${esc(cur.q||"")}</textarea>
+          <div class="sample ${shown?'show':''}" id="s_${key}">
+            <div class="sbox"><div class="h">Sample question</div>${u.sample}</div>
+            ${u.teach?`<div class="teach">${u.teach}</div>`:``}
+            <div class="rate" role="radiogroup" aria-label="How does your question compare?">
+              <label class="same"><input type="radio" name="r_${key}" value="same" ${cur.rate==='same'?'checked':''}><span>Same idea, different words</span></label>
+              <label class="diff"><input type="radio" name="r_${key}" value="diff" ${cur.rate==='diff'?'checked':''}><span>Truly different</span></label>
+              <label class="miss"><input type="radio" name="r_${key}" value="miss" ${cur.rate==='miss'?'checked':''}><span>I missed this / mine was off</span></label>
+            </div>
+          </div>
+        </div>`;
+      });
+      html += `<div style="margin-top:14px">
+        <button class="btn accent" data-reveal="${pi}">${shown?'Samples shown':'Compare with the sample questions ▸'}</button>
+      </div>
+      <div class="pnote">
+        <label for="pn${pi}">Across this paragraph, how often was your question the same idea vs. truly different — and what does that tell you?</label>
+        <textarea id="pn${pi}" data-pnote="${pi}" placeholder="Your reflection on this paragraph…">${esc(revNote["p"+pi]||"")}</textarea>
+      </div>
+      </div>`;
+    });
+    html += `<div class="actions"><button class="btn accent" id="saveRev">Save</button><span class="savemsg" id="revSaved"></span></div>`;
+    main.innerHTML = `<div class="docwrap">${html}</div>`;
+    wireReverse();
+  }
+
+  function collectReverse(){
+    document.querySelectorAll("[data-rev]").forEach(t=>{
+      const k=t.dataset.rev; rev[k]=rev[k]||{}; rev[k].q=t.value;
+    });
+    document.querySelectorAll("[type=radio]:checked").forEach(r=>{
+      const k=r.name.slice(2); rev[k]=rev[k]||{}; rev[k].rate=r.value;
+    });
+    document.querySelectorAll("[data-pnote]").forEach(t=>{ revNote["p"+t.dataset.pnote]=t.value; });
+    save("lc_rev",rev); save("lc_revNote",revNote);
+  }
+  function wireReverse(){
+    document.querySelectorAll("[data-reveal]").forEach(b=>{
+      b.onclick=()=>{ collectReverse(); revShown["p"+b.dataset.reveal]=true; save("lc_revShown",revShown); renderReverse(); };
+    });
+    document.querySelectorAll("[type=radio]").forEach(r=>{ r.onchange=()=>{ collectReverse(); }; });
+    const s=document.getElementById("saveRev");
+    s.onclick=()=>{ collectReverse(); buildStepper(); const m=document.getElementById("revSaved"); m.textContent="Saved ✓"; setTimeout(()=>m.textContent="",1400); };
+  }
+
+  /* ---------- REFLECTION ---------- */
+  function renderReflection(){
+    let html = `<div class="kicker">Stage 3 · Reflection &amp; Export</div>
+      <h1>What did this reveal about how you ask questions?</h1>
+      <div class="sub">Answer briefly, then export your submission. Your forward-drill missteps and reverse-drill self-ratings are included automatically.</div>`;
+    C.reflection.forEach((qq,i)=>{
+      html += `<div class="field">
+        <label for="rf${i}"><span class="qnum">Q${i+1}</span>${qq.q}</label>
+        <textarea id="rf${i}" data-rf="${i}" placeholder="Your answer…">${esc(reflect[i]||"")}</textarea>
+      </div>`;
+    });
+    html += `<div class="actions">
+        <button class="btn accent" id="saveRef">Save answers</button>
+        <button class="btn accent" id="exportAll">Export submission (.txt)</button>
+        <span class="savemsg" id="refSaved"></span>
+      </div>
+      <div class="callout"><span class="h">Privacy</span>Everything you typed lives only in this browser tab on this device and is erased when you close it. Export the file and submit it with your on-paper work.</div>`;
+    main.innerHTML = `<div class="docwrap">${html}</div>`;
+    const collect=()=>{ document.querySelectorAll("[data-rf]").forEach(t=>reflect[t.dataset.rf]=t.value); save("lc_reflect",reflect); };
+    document.getElementById("saveRef").onclick=()=>{ collect(); const m=document.getElementById("refSaved"); m.textContent="Saved ✓"; setTimeout(()=>m.textContent="",1400); };
+    document.getElementById("exportAll").onclick=()=>{ collect(); exportTxt(); };
+  }
+
+  /* ---------- export ---------- */
+  function strip(s){ return String(s||"").replace(/<[^>]+>/g," ").replace(/&amp;/g,"&").replace(/&lt;/g,"<").replace(/&gt;/g,">").replace(/\s+/g," ").trim(); }
+  function exportTxt(){
+    const L=[];
+    L.push("LEX·CHAIN — CHAPTER 3 DRILL — SUBMISSION");
+    L.push("Exported: "+new Date().toLocaleString());
+    L.push("");
+    L.push("STAGE 1 — FORWARD DRILL (next-question choices)");
+    L.push("------------------------------------------------");
+    C.steps.forEach((st,i)=>{
+      L.push("Q"+(i+1)+" ["+st.qtype+"]: "+strip(st.q));
+      const att=branch.attempts[i]||[];
+      if(!att.length){ L.push("   (not attempted)"); }
+      att.forEach(ci=>{
+        const c=st.choices[ci];
+        L.push("   "+(c.correct?"[correct]":"[misstep — "+strip(c.tag)+"]")+" "+String.fromCharCode(65+ci)+". "+strip(c.t));
+      });
+      L.push("");
+    });
+    L.push("STAGE 2 — REVERSE DRILL (your questions)");
+    L.push("------------------------------------------------");
+    C.reverse.forEach((p,pi)=>{
+      L.push(strip(p.title));
+      p.units.forEach((u,ui)=>{
+        const k="p"+pi+"u"+ui; const cur=rev[k]||{};
+        const rl={same:"same idea / different words",diff:"truly different",miss:"missed / off"}[cur.rate]||"(no self-rating)";
+        L.push("  Unit "+(ui+1)+":");
+        L.push("    Your Q : "+(strip(cur.q)||"[blank]"));
+        L.push("    Sample : "+strip(u.sample));
+        L.push("    Rating : "+rl);
+      });
+      L.push("  Paragraph reflection: "+(strip(revNote["p"+pi])||"[blank]"));
+      L.push("");
+    });
+    L.push("STAGE 3 — REFLECTION");
+    L.push("------------------------------------------------");
+    C.reflection.forEach((qq,i)=>{
+      L.push((i+1)+". "+strip(qq.q));
+      L.push("   "+(strip(reflect[i])||"[no answer]"));
+      L.push("");
+    });
+    const blob=new Blob([L.join("\n")],{type:"text/plain"});
+    const url=URL.createObjectURL(blob);
+    const a=document.createElement("a"); a.href=url; a.download="lex-chain-submission.txt";
+    document.body.appendChild(a); a.click(); setTimeout(()=>{URL.revokeObjectURL(url); a.remove();},300);
+  }
+
+  /* ---------- render switch ---------- */
+  function render(){
+    document.body.classList.toggle("guided", mode==="guided");
+    if(stage===0) renderForward();
+    else if(stage===1) renderReverse();
+    else renderReflection();
+    main.scrollTop=0;
+  }
+
+  /* ---------- chrome wiring ---------- */
+  stepper.addEventListener("click",e=>{
+    const b=e.target.closest("[data-stage]"); if(!b) return;
+    if(stage===1) collectReverse();
+    stage=+b.dataset.stage; store.set("lc_stage",String(stage));
+    buildStepper(); render();
+  });
+  document.querySelectorAll("#modeSeg button").forEach(b=>{
+    b.classList.toggle("on", b.dataset.mode===mode);
+    b.onclick=()=>{ mode=b.dataset.mode; store.set("lc_mode",mode);
+      document.querySelectorAll("#modeSeg button").forEach(x=>x.classList.toggle("on",x.dataset.mode===mode));
+      render(); };
+  });
+  document.getElementById("exportBtn").onclick=()=>{ if(stage===1) collectReverse(); exportTxt(); };
+  document.getElementById("resetBtn").onclick=()=>{
+    if(!confirm("Reset this exercise? All your entries will be cleared.")) return;
+    ["lc_branch","lc_rev","lc_revShown","lc_revNote","lc_reflect","lc_stage"].forEach(k=>store.set(k, k==="lc_stage"?"0":"{}"));
+    branch={ attempts:C.steps.map(()=>[]), solved:C.steps.map(()=>false) };
+    rev={}; revShown={}; revNote={}; reflect={}; stage=0; unlocked=0;
+    buildStepper(); render();
+  };
+
+  /* ---------- boot ---------- */
+  buildStepper();
+  render();
+})();
+</script>
+<!--shell:modnav:start-->
+<nav class="modnav" aria-label="Module navigation">
+  <p class="modnav-crumb">Part of <a href="../../ch-3/">Ch. 3 · The Question Method of Legal Research</a></p>
+  <p class="modnav-verified">Authorities verified as of 2026-07-09. The law changes — run the method, don’t trust the module.</p>
+  <div class="modnav-links">
+    <a class="modnav-link prev" href="../../modules/question-method/index.html"><span class="dir">← Previous</span><span class="t">Notice of Claim — Research Sandbox</span></a>
+    <a class="modnav-link next" href="../../modules/type-the-question/index.html"><span class="dir">Next →</span><span class="t">Type the Question</span></a>
+  </div>
+</nav>
+<!--shell:modnav:end-->
+
+<!--shell:footer:start-->
+<footer class="foot">
+  <div class="wrap">
+    <span>The Question Method of Legal Research &mdash; interactive modules.</span>
+    <span>Constantly in beta · built by Cas Laskowski</span>
+  </div>
+</footer>
+<!--shell:footer:end-->
