+        { t: "A 50-state survey", good: false, fb: "Survey tools answer how-many-jurisdictions questions. Yours is orientation. (Ch. 4)" } ] },
+    { skill: "Pick the source \u00b7 Ch. 4",
+      q: "You know the area well and need the leading treatment of its structure \u2014 elements, tests, and where the debates lie. Which source?",
+      opts: [
+        { t: "A treatise", good: true, fb: "Foundational exploratory questions want the treatise: the source organized to give a field's structure. (Ch. 4)" },
+        { t: "An encyclopedia", good: false, fb: "The encyclopedia orients a no-clue question; you are past orientation and need depth and structure. (Ch. 4)" },
+        { t: "A headnote", good: false, fb: "A headnote summarizes one point in one opinion \u2014 a finding tool, not a map of the field. (Ch. 5)" },
+        { t: "The Federal Register", good: false, fb: "The FR is the daily record of rulemaking \u2014 wrong shelf entirely for doctrinal structure. (Ch. 7)" } ] },
+    { skill: "Rank the authority \u00b7 Ch. 1",
+      q: "Your matter is in your state's trial court. Which of these must that court follow?",
+      opts: [
+        { t: "A decision of your state's highest court", good: true, fb: "Binding authority: decisions of higher courts in the court's own system. The rest is at most persuasive. (Ch. 1)" },
+        { t: "A decision of a neighboring state's highest court", good: false, fb: "Another sovereign's law \u2014 persuasive, never binding, however eminent the court. (Ch. 1)" },
+        { t: "A Restatement section", good: false, fb: "Among the most persuasive secondary authorities \u2014 but secondary: it becomes binding only if your courts adopt it. (Ch. 1)" },
+        { t: "A treatise passage the judge once cited", good: false, fb: "Persuasive at most. A citation in one opinion does not convert a secondary source into law. (Ch. 1)" } ] },
+    { skill: "Rank the authority \u00b7 Ch. 1 / Ch. 5",
+      q: "An opinion resolves the appeal on one ground, then adds: \u201cwe note that had the contract been oral, the result would likely differ.\u201d What is that added sentence?",
+      opts: [
+        { t: "Dictum \u2014 persuasive at most, never binding", good: true, fb: "A statement not necessary to the decision is dictum. Only the holding \u2014 the resolution necessary to the judgment \u2014 carries precedential weight. (Ch. 1, Ch. 5)" },
+        { t: "The holding", good: false, fb: "The holding is the court's resolution of the issue necessary to its decision; a had-it-been-otherwise aside is not necessary to anything. (Ch. 5)" },
+        { t: "A headnote", good: false, fb: "Headnotes are editor-written summaries added by the publisher \u2014 this sentence is the court's own text, just non-essential. (Ch. 5)" },
+        { t: "Binding authority on oral contracts", good: false, fb: "Exactly the trap: it reads like a rule, but it decided nothing and binds no one. (Ch. 5)" } ] },
+    { skill: "Statutes first \u00b7 Ch. 6",
+      q: "A friend insists \u201cthe common law governs this, just find cases.\u201d Before case-hunting, the disciplined first check is:",
+      opts: [
+        { t: "Whether a statute has occupied or modified the area", good: true, fb: "Legislatures overwrite common law constantly. Checking the code first prevents building an analysis on rules a statute has displaced. (Ch. 6)" },
+        { t: "Whether any case is less than five years old", good: false, fb: "Recency matters later; the threshold question is which body of law governs at all. (Ch. 6)" },
+        { t: "Whether a law review article agrees", good: false, fb: "Commentary can't settle what governs \u2014 the code can. (Ch. 6)" },
+        { t: "Whether the jurisdiction publishes an annotated code", good: false, fb: "It almost certainly does \u2014 and that's the tool for the real first check: has a statute spoken? (Ch. 6)" } ] },
+    { skill: "Scoped answers \u00b7 Ch. 3",
+      q: "Your question: <i>\u201cDoes our state require drivers to report accidents to the police?\u201d</i> Which recorded answer is properly scoped to it?",
+      opts: [
+        { t: "\u201cYes \u2014 the vehicle code requires a report when damage or injury passes a threshold.\u201d", good: true, fb: "Scoped: it answers the question asked and nothing more. The exceptions, deadlines, and penalties are the next questions, not this answer. (Ch. 3)" },
+        { t: "\u201cYes \u2014 and the deadline is short, penalties include license suspension, insurers must also be notified, and there's an exception for private property.\u201d", good: false, fb: "A compound answer \u2014 it reaches past its question into four later ones. Each of those items should enter the log when its own question is asked. (Ch. 3)" },
+        { t: "\u201cAccident law is complicated and fact-dependent.\u201d", good: false, fb: "Not an answer at all \u2014 no source, no rule, nothing the outline can hold. (Ch. 3)" },
+        { t: "\u201cProbably \u2014 most states do.\u201d", good: false, fb: "The question asked about your state; a most-states answer is a survey answer to a different question. (Ch. 3)" } ] },
+    { skill: "Next question \u00b7 Ch. 3",
+      q: "Logged answer: <i>\u201cThe statute requires landlords to return the deposit within a reasonable time.\u201d</i> Which next question follows from that answer?",
+      opts: [
+        { t: "\u201cHow is \u2018a reasonable time\u2019 measured under this statute?\u201d", good: true, fb: "The answer surfaced an undefined standard; the next question interrogates it. Answer-driven chaining is the method's engine. (Ch. 3)" },
+        { t: "\u201cWhat damages can the tenant get for retaliatory eviction?\u201d", good: false, fb: "A leap \u2014 nothing in the logged answer raised retaliation. Compression skips the questions in between. (Ch. 3)" },
+        { t: "\u201cIs the deposit-return rule preempted by federal banking law?\u201d", good: false, fb: "A term (preemption) and a doctrine the research hasn't surfaced \u2014 asked out of discovery order. (Ch. 3)" },
+        { t: "\u201cHow much was this tenant's deposit?\u201d", good: false, fb: "A factual/investigative question for the client file, not a research question the law answers. (Ch. 3)" } ] },
+    { skill: "Read the source \u00b7 Ch. 4 / App. A",
+      q: "A treatise paragraph nails your issue, and its footnote lists six cases. The method's move is:",
+      opts: [
+        { t: "Read the one case that answers the question you are holding; log the rest as later questions with citations noted", good: true, fb: "Footnotes are mined in the order your questions dictate \u2014 one case now, five logged for their own turns. (Ch. 4, App. A)" },
+        { t: "Read all six before continuing", good: false, fb: "Reading six cases to answer one question is how afternoons vanish. The question sets the reading order. (App. A)" },
+        { t: "Cite the treatise itself and move on", good: false, fb: "With narrow exceptions you cite the primary authority the treatise points to, not the treatise. (Ch. 4)" },
+        { t: "Ignore the footnote \u2014 the narrative already answered the question", good: false, fb: "The narrative tells you what the law is; the footnotes tell you where to confirm it. Verification is not optional. (App. A)" } ] },
+    { skill: "Regulations \u00b7 Ch. 7",
+      q: "The CFR section's bare text won't tell you <em>why</em> the agency chose its rule. The thread to pull is:",
+      opts: [
+        { t: "The source note \u2014 it cites the Federal Register document whose preamble explains the rule", good: true, fb: "The source note names the FR document that created or last amended the part; its preamble is the regulatory equivalent of legislative history. (Ch. 7)" },
+        { t: "The authority note", good: false, fb: "The authority note cites the empowering statute \u2014 essential for a stays-within-the-grant question, but not the agency's reasoning. (Ch. 7)" },
+        { t: "The LSA", good: false, fb: "The LSA tracks which sections changed since the annual edition \u2014 currency, not reasoning. (Ch. 7)" },
+        { t: "The table of contents of the CFR title", good: false, fb: "A finding aid for locating text, not for explaining it. (Ch. 7)" } ] },
+    { skill: "Citators \u00b7 Ch. 5",
+      q: "Your key case comes back from the citator with a negative-treatment flag. The professional response is:",
+      opts: [
+        { t: "Read the citing opinion and ask whether the treatment touches the point you're citing for", good: true, fb: "A flag is a prompt to investigate, not a verdict. A case can be overruled on one point and perfectly good on yours. (Ch. 5)" },
+        { t: "Drop the case immediately", good: false, fb: "Overreaction \u2014 flags mark treatment somewhere in the case, not necessarily on your point. Read first. (Ch. 5)" },
+        { t: "Cite it anyway; flags are editorial noise", good: false, fb: "The opposite failure \u2014 citing negatively-treated authority unexamined is the classic verification error. (Ch. 5)" },
+        { t: "Find a newer case with the same headnote number", good: false, fb: "Headnote-matching without reading repeats the same gamble with a different case. (Ch. 5)" } ] },
+    { skill: "Fix the search \u00b7 Ch. 9",
+      q: "<i>\u201cslip AND fall AND store\u201d</i> returns 6,200 results. The correction is:",
+      opts: [
+        { t: "Bind concepts with proximity, add the concept that makes your question specific, filter jurisdiction", good: true, fb: "The narrowing sequence: proximity connectors, a third concept, jurisdiction and date filters \u2014 aimed at your question, not the topic. (Ch. 9)" },
+        { t: "Add more OR synonyms", good: false, fb: "OR-expansion broadens \u2014 the prescription for zero results, not 6,200. (Ch. 9)" },
+        { t: "Read the first page and stop", good: false, fb: "Relevance ranking on a broad query is a popularity contest among the words, not an answer to your question. (Ch. 9)" },
+        { t: "Switch databases and rerun it unchanged", good: false, fb: "The same broad string is broad everywhere. (Ch. 9)" } ] },
+    { skill: "No results vs. no law \u00b7 Ch. 8\u20139",
+      q: "One search returned nothing, and the memo draft now says \u201cthere is no law on this point.\u201d What's wrong?",
+      opts: [
+        { t: "The no-law call isn't defensible until alternative terms, loosened constraints, persuasive jurisdictions, and secondary sources are exhausted \u2014 and documented", good: true, fb: "\u201cThere is no law\u201d is a powerful argument; \u201cI could not find any law\u201d is a confession. One search establishes only the second. (Ch. 8\u20139)" },
+        { t: "Nothing \u2014 zero results means zero law", good: false, fb: "Zero results means one of two things, and only exhausting the alternatives tells you which. (Ch. 9)" },
+        { t: "The draft should say the law is \u2018unclear\u2019 instead", good: false, fb: "Hedged wording doesn't fix undone research \u2014 the alternatives still have to be run and recorded. (Ch. 9)" },
+        { t: "The search should be rerun in the same form to confirm", good: false, fb: "Repeating the identical search confirms only that the same string still fails. Vary it. (Ch. 9)" } ] },
+    { skill: "The log \u00b7 Ch. 3 / Ch. 9",
+      q: "Two records run side by side through a project. The Research Log tracks the questions and answers; the search log tracks:",
+      opts: [
+        { t: "Each exact search string, the database, the result count, and whether it was productive", good: true, fb: "The search log is the query-level record \u2014 it keeps you from repeating yourself and it is the evidence your closure documentation stands on. (Ch. 9)" },
+        { t: "Your billable time per task", good: false, fb: "Worth tracking, but it's a practice-management record, not a research one. (Ch. 9)" },
+        { t: "The full text of every result you opened", good: false, fb: "That's a filing cabinet, not a log \u2014 the log records the queries and their yield. (Ch. 9)" },
+        { t: "Only the searches that worked", good: false, fb: "The unproductive strings are half the value: they prove comprehensiveness and stop you rerunning them. (Ch. 9)" } ] }
+  ];
+
+  var deck = document.getElementById("deck"),
+      score = document.getElementById("score"),
+      tally = document.getElementById("tally"),
+      fill = document.getElementById("progfill"),
+      doneBox = document.getElementById("done");
+  var answered = 0, right = 0;
+
+  function shuffle(a) {
+    var arr = a.slice();
+    for (var i = arr.length - 1; i > 0; i--) {
+      var j = Math.floor(Math.random() * (i + 1)), t = arr[i]; arr[i] = arr[j]; arr[j] = t;
+    }
+    return arr;
+  }
+
+  function render() {
+    deck.innerHTML = "";
+    doneBox.classList.remove("show");
+    answered = 0; right = 0;
+    score.textContent = "0 of " + BANK.length + " answered";
+    tally.textContent = "";
+    fill.style.width = "0";
+    shuffle(BANK).forEach(function (item, n) {
+      var skillTag = el("span", { class: "skill" }, ["Skill: hidden until you answer"]);
+      var card = el("div", { class: "card" }, [
+        el("p", { class: "qno" }, [el("span", {}, ["Item " + (n + 1) + " of " + BANK.length]), skillTag]),
+        el("p", { class: "q", html: item.q })
+      ]);
+      var wrap = el("div", { class: "opts", role: "group", "aria-label": "Answer choices" });
+      var fb = QM.live(el("div", { class: "fb" }));
+      fb.hidden = true;
+      var done = false;
+      shuffle(item.opts).forEach(function (o) {
+        var b = el("button", { class: "opt", type: "button" }, [o.t]);
+        b.addEventListener("click", function () {
+          if (done) return;
+          done = true;
+          wrap.querySelectorAll(".opt").forEach(function (x) {
+            x.disabled = true;
+            if (x.textContent === o.t && !o.good) x.classList.add("bad");
+          });
+          wrap.querySelectorAll(".opt").forEach(function (x) {
+            item.opts.forEach(function (oo) { if (oo.good && x.textContent === oo.t) x.classList.add("good"); });
+          });
+          skillTag.textContent = item.skill;
+          fb.hidden = false;
+          fb.classList.add(o.good ? "good" : "bad");
+          QM.announce(fb, (o.good ? "Right. " : "Not quite. ") + o.fb);
+          answered++; if (o.good) right++;
+          score.textContent = answered + " of " + BANK.length + " answered";
+          tally.textContent = right + " correct";
+          fill.style.width = Math.round(answered / BANK.length * 100) + "%";
+          if (window.ExportReflect) ExportReflect.log(item.skill,
+            o.good ? "correct" : "incorrect \u2014 chose: " + o.t);
+          if (answered === BANK.length) {
+            var pct = Math.round(right / BANK.length * 100);
+            doneBox.innerHTML = "<p class=\"qno\">Pass complete</p><div class=\"big\">" + right + " / " + BANK.length + " (" + pct + "%)</div>" +
+              "<p>Interleaving is spaced practice's partner: come back in a few days and the deck will be reshuffled. The feedback on anything you missed names the chapter to revisit.</p>";
+            doneBox.classList.add("show");
+            if (window.ExportReflect) ExportReflect.log("Pass complete", right + " / " + BANK.length);
+          }
+        });
+        wrap.appendChild(b);
+      });
+      card.appendChild(wrap); card.appendChild(fb);
+      deck.appendChild(card);
+    });
+  }
+  document.getElementById("reshuffle").addEventListener("click", function () {
+    if (answered === 0 || answered === BANK.length ||
+        window.confirm("Reshuffle now? Your progress on this pass resets (answers already logged stay in your record).")) render();
+  });
+  render();
+
+  /* the shared Research Log follows the student between modules */
+  if (window.ResearchLog) ResearchLog.mount({ parent: document.getElementById("export-slot").parentNode,
+    before: document.getElementById("export-slot") });
+
+  if (window.ExportReflect) ExportReflect.mount(document.getElementById("export-slot"), {
+    module: "Mixed Review \u2014 The Diagnostic Moves",
+    chapter: "Chapter 9 \u2014 Narrowing and Closing Out Your Research (cumulative, Ch. 1\u20139)",
+    intro: "Every answer is collected locally, including across reshuffles. Add a reflection and download the record to submit.",
+    prompts: [
+      "Which skill's items did you recognize slowest, and which chapter will you revisit first?",
+      "Interleaving forces you to name the move before making it. Where in a real research project does that same recognition step happen?"
+    ]
+  });
+})();
+</script>
+</body>
+</html>
