+<script src="../../js/lib.js"></script>
+<script src="../../js/export-reflect.js"></script>
+<script>
+(function(){
+  "use strict";
+  var el = QM.el;
+
+  /* ---- 1: pipeline ---- */
+  var STAGES = {
+    nprm: ["Notice of Proposed Rulemaking (NPRM)",
+      "<p>The agency publishes a proposed rule in the Federal Register, explaining what it intends to do and why \u2014 the proposed text plus a preamble laying out the agency's reasoning.</p><p><b>For the researcher:</b> the NPRM shows original intent, and it opens the public comment period.</p>"],
+    comment: ["Public comment",
+      "<p>Stakeholders file comments on the proposal. The agency must consider them before finalizing.</p><p><b>For the researcher:</b> the comments show what the regulated world objected to \u2014 useful for understanding why the final rule reads the way it does.</p>"],
+    final: ["Final rule",
+      "<p>The agency publishes the final rule in the Federal Register: binding text, an effective date, and a detailed preamble responding to significant comments.</p><p><b>For the researcher:</b> that preamble is often your single best interpretive resource \u2014 the regulatory equivalent of legislative history. Overlooking it is the most common way researchers misread what a regulation requires.</p>"],
+    cfr: ["Codification",
+      "<p>The final rule is codified into the Code of Federal Regulations, organized by subject into 50 titles.</p><p><b>For the researcher:</b> the CFR (and the daily-updated eCFR) is the official home of the operative text \u2014 but the text alone often cannot answer your question. The part's source note cites the Federal Register document behind it: pull that thread to reach the preamble.</p>"]
+  };
+  var pSeen = {}, pTitle = document.getElementById("pipe-title"),
+      pBody = document.getElementById("pipe-body"), pCount = document.getElementById("pipe-seen");
+  document.querySelectorAll(".stage").forEach(function (b) {
+    b.addEventListener("click", function () {
+      document.querySelectorAll(".stage").forEach(function (x) { x.setAttribute("aria-expanded", "false"); });
+      b.setAttribute("aria-expanded", "true");
+      var k = b.getAttribute("data-stage"), S = STAGES[k];
+      pTitle.textContent = S[0];
+      pBody.innerHTML = S[1];
+      if (!pSeen[k]) {
+        pSeen[k] = true;
+        if (window.ExportReflect) ExportReflect.log("Explored pipeline stage", S[0]);
+      }
+      pCount.textContent = "Explored " + Object.keys(pSeen).length + " of 4 stages";
+    });
+  });
+
+  /* ---- 2: citation anatomy ---- */
+  var BITS = {
+    title: "\u201c40\u201d is the title \u2014 one of 50 subject titles. Title 40 is Protection of Environment, the EPA's home.",
+    part:  "\u201cPart 50\u201d groups related sections \u2014 here, the National Ambient Air Quality Standards. Between title and part, the chapter identifies the agency.",
+    sec:   "\u201c.8\u201d is the section \u2014 the operative rule itself (here, the carbon monoxide standards). Sections are what you cite."
+  };
+  var citefb = document.getElementById("citefb"), citeSeen = {};
+  document.querySelectorAll(".citebit").forEach(function (b) {
+    b.addEventListener("click", function () {
+      var k = b.getAttribute("data-bit");
+      QM.announce(citefb, BITS[k]);
+      if (!citeSeen[k]) {
+        citeSeen[k] = true;
+        if (window.ExportReflect) ExportReflect.log("Read the citation", k);
+      }
+    });
+  });
+
+  /* ---- shared check-card engine ---- */
+  function checkCard(host, item, n, of, logLabel, onDone) {
+    var card = el("div", { class: "card" }, [
+      el("p", { class: "qno" }, [item.head + " " + n + " of " + of]),
+      el("p", { class: "q", html: item.q })
+    ]);
+    var wrap = el("div", { class: "opts", role: "group", "aria-label": "Answer choices" });
+    var fb = QM.live(el("div", { class: "fb" }));
+    fb.hidden = true;
+    var done = false;
+    item.opts.forEach(function (o, i) {
+      var b = el("button", { class: "opt", type: "button" }, [o.t]);
+      b.addEventListener("click", function () {
+        if (done) return;
+        done = true;
+        wrap.querySelectorAll(".opt").forEach(function (x, xi) {
+          x.disabled = true;
+          if (item.opts[xi].good) x.classList.add("good");
+          else if (xi === i) x.classList.add("bad");
+        });
+        fb.hidden = false;
+        fb.classList.add(o.good ? "good" : "bad");
+        QM.announce(fb, (o.good ? "Right. " : "Not quite. ") + o.fb);
+        if (window.ExportReflect) ExportReflect.log(logLabel + " " + n,
+          o.good ? "correct" : "incorrect \u2014 chose: " + o.t);
+        if (onDone) onDone(o.good);
+      });
+      wrap.appendChild(b);
+    });
+    card.appendChild(wrap); card.appendChild(fb);
+    host.appendChild(card);
+  }
+
+  /* ---- 3: entry routes ---- */
+  var ROUTES = [
+    { head: "Question", q: "<i>\u201cThe statute requires \u2018reasonable accommodation\u2019 \u2014 what does compliance actually look like?\u201d</i> You have the annotated statute open in front of you. What is the most reliable way into the regulations?",
+      opts: [
+        { t: "Follow the annotated code's \u201cImplementing Regulations\u201d note to the CFR part", good: true,
+          fb: "A focusing question that begins with a statute is answered by following the annotation straight to the relevant CFR part \u2014 no cold search required." },
+        { t: "Run a keyword search across the whole CFR", good: false,
+          fb: "A cold CFR search is the least reliable route when you already hold the statute \u2014 the annotated code has already made the connection for you." },
+        { t: "Read today's Federal Register", good: false,
+          fb: "The daily Federal Register is for recent and proposed action, not for locating the existing rules that implement a statute you hold." },
+        { t: "Browse the agency's press releases", good: false,
+          fb: "Agency sites can help, but press releases are not the regulations. The annotation takes you to the operative text directly." } ] },
+    { head: "Question", q: "<i>\u201cWhat does the agency mean by \u2018service animal\u2019?\u201d</i> \u2014 a term the statute delegated to the agency to define. Where does the answer live?",
+      opts: [
+        { t: "The regulation's definitions section, in the relevant CFR part", good: true,
+          fb: "When a statute delegates a term to an agency, the agency's regulatory definition controls. A definitional question about a delegated term is answered by the regulation's definitions section." },
+        { t: "A legal dictionary", good: false,
+          fb: "A dictionary gives a working definition \u2014 fine for orientation, but here precision is critical and the agency's own definition is the law." },
+        { t: "The daily Federal Register", good: false,
+          fb: "The FR is where the definition was once proposed and adopted, but the current operative definition is codified in the CFR part's definitions section." },
+        { t: "A treatise on administrative law", good: false,
+          fb: "A treatise explains the field's structure; it does not supply the controlling text of a delegated definition. Go to the regulation." } ] },
+    { head: "Question", q: "<i>\u201cIs the agency planning to change this rule?\u201d</i> You have the current CFR text. Where do you look for what is coming?",
+      opts: [
+        { t: "The Federal Register (and the Unified Regulatory Agenda)", good: true,
+          fb: "Proposed rules, interim final rules, and the twice-yearly Unified Regulatory Agenda live in the Federal Register world \u2014 that is where regulatory futures are announced." },
+        { t: "The annual print CFR", good: false,
+          fb: "The annual CFR is a snapshot of what is codified \u2014 it cannot show you what is merely proposed." },
+        { t: "The List of CFR Sections Affected", good: false,
+          fb: "The LSA records changes already made to CFR sections since the annual edition \u2014 it looks backward from the codification, not forward to proposals." },
+        { t: "A citator (KeyCite or Shepard's)", good: false,
+          fb: "Citators track how courts have treated the regulation \u2014 invaluable for validity, but not where proposed changes are announced." } ] }
+  ];
+  var routesHost = document.getElementById("routes");
+  ROUTES.forEach(function (item, i) { checkCard(routesHost, item, i + 1, ROUTES.length, "Entry route"); });
+
+  /* ---- 4: currency checklist matching ---- */
+  var TOOLS = ["The eCFR", "The List of CFR Sections Affected (LSA)", "The Federal Register",
+               "A citator (KeyCite or Shepard's)", "The agency's website"];
+  function toolOpts(goodIdx, fbGood, fbWrong) {
+    return TOOLS.map(function (t, i) {
+      return { t: t, good: i === goodIdx, fb: i === goodIdx ? fbGood : fbWrong[i] };
+    });
+  }
+  var CURRENCY = [
+    { head: "Catch", q: "You are working from the annual print CFR edition. <b>Which tool catches amendments made since that edition went to press?</b>",
+      opts: toolOpts(1,
+        "The LSA is the monthly record of exactly that: which CFR sections have changed since the last annual update.",
+        ["The eCFR would work if you were online \u2014 but the tool built to reconcile a print annual edition is the LSA.",
+         "", "The FR holds the amending documents, but the LSA is the index that tells you which sections were touched.",
+         "A citator tracks court treatment, not intervening amendments.",
+         "Agency sites are inconsistent about amendment history; the LSA is the systematic record."]) },
+    { head: "Catch", q: "A regulation still appears, word for word, in the CFR text \u2014 but a court struck it down last year. <b>Which tool catches that?</b>",
+      opts: toolOpts(3,
+        "Only a citator surfaces judicial treatment. A regulation invalidated by a court is no longer enforceable even though it still appears in the CFR text \u2014 this is the trap the citator exists to catch.",
+        ["The eCFR shows current codified text \u2014 and an invalidated rule can still sit in it.",
+         "The LSA tracks amendments to the text, not court decisions about it.",
+         "The FR would show an agency's response, if any \u2014 but the invalidation itself lives in case law.",
+         "", "The agency may note it eventually, but the systematic check is the citator."]) },
+    { head: "Catch", q: "You need the most current codified text available for free, with a note showing the date it is updated through. <b>Which tool?</b>",
+      opts: toolOpts(0,
+        "The eCFR is updated daily and carries an updated-through date on each title \u2014 the most current freely available source of codified text.",
+        ["", "The LSA supplements the annual edition; the eCFR simply is current.",
+         "The FR is the daily stream of documents, not consolidated codified text.",
+         "Citators judge validity, not currency of text.",
+         "Agency postings vary; the eCFR is the systematic current text."]) },
+    { head: "Catch", q: "The rule's text has not changed, but the agency has posted a compliance bulletin that changes how it enforces the rule in practice. <b>Which tool catches that?</b>",
+      opts: toolOpts(4,
+        "Agency websites carry the guidance, bulletins, and enforcement-policy changes that can shift how a regulation operates before its text is formally amended.",
+        ["The eCFR only shows the text \u2014 which, here, has not changed.",
+         "The LSA tracks text changes; there are none.",
+         "Some guidance appears in the FR, but compliance bulletins typically live on the agency's own site.",
+         "A citator tracks courts, not agency practice.", ""]) },
+    { head: "Catch", q: "You want to know whether a proposed or interim rule is already in motion that would affect your section. <b>Which tool?</b>",
+      opts: toolOpts(2,
+        "The Federal Register carries proposed rules, interim final rules, and final rules \u2014 plus the Unified Regulatory Agenda listing what agencies plan to do.",
+        ["The eCFR shows what is codified now, not what is proposed.",
+         "The LSA looks backward at completed changes.",
+         "", "Citators track courts, not rulemaking in motion.",
+         "The agency site may mention it, but the official record of proposals is the FR."]) }
+  ];
+  var curHost = document.getElementById("currency"),
+      tally2 = document.getElementById("tally2"),
+      cRight = 0, cDone = 0;
+  CURRENCY.forEach(function (item, i) {
+    checkCard(curHost, item, i + 1, CURRENCY.length, "Currency tool", function (ok) {
+      cDone++; if (ok) cRight++;
+      tally2.textContent = cDone + " of " + CURRENCY.length + " matched \u00b7 " + cRight + " correct";
+      if (cDone === CURRENCY.length && window.ExportReflect)
+        ExportReflect.log("Currency checklist final", cRight + " / " + CURRENCY.length);
+    });
+  });
+
+  if (window.ExportReflect) ExportReflect.mount(document.getElementById("export-slot"), {
+    module: "How to Find a Regulation",
+    chapter: "Chapter 7 \u2014 Basic Regulations and Administrative Research",
+    intro: "Your exploration and answers are collected locally as you work. Add a reflection and download the record to submit.",
+    prompts: [
+      "The book's shorthand is: NPRM = intent, comments = objections, final-rule preamble = the agency's answers. Which of the three do you expect to reach for first, and why?",
+      "Write the research question that would send you to the source note of a CFR part."
+    ]
+  });
+})();
+</script>
